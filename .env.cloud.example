PORT=3000
NODE_ENV=development
JWT_SECRET=troque_esta_chave_em_producao_com_uma_chave_forte

# Cole aqui a connection string do PostgreSQL em nuvem.
# Exemplos de provedores: Neon, Supabase, Railway, Render, AWS RDS.
# Mantenha sslmode=require quando o provedor fornecer essa opção.
DATABASE_URL=postgresql://USUARIO:SENHA@HOST/BANCO?sslmode=require
