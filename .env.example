PORT=3000
NODE_ENV=development
JWT_SECRET=troque_esta_chave_em_producao_com_uma_chave_forte
DATABASE_URL=postgres://crm_user:crm_password@localhost:5432/crm_saas

# simulated mantém os fluxos de e-mail funcionando em teste sem enviar mensagens reais.
# Para produção, configure um provedor de e-mail e altere a implementação SMTP em src/services/email.service.js.
EMAIL_DELIVERY_MODE=simulated
EMAIL_FROM=CRM <no-reply@crm.local>

# Para envio real, use EMAIL_DELIVERY_MODE=smtp e preencha:
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
